{#
  Template: single-file-fix (ACP mode)

  Renders the ACP `prompt` parts array for a focused single-file edit.
  Output is JSON; the dispatcher parses it and embeds it under
  `params.prompt` in a `session/prompt` request.

  Inputs:
    prompt_text       (str) — the operator's prompt body, verbatim
    target_file_uri   (str) — `file://` absolute URI to the target file
    target_file_name  (str) — basename, for display in the agent's UI
    target_file_path  (str) — absolute filesystem path (no scheme)

  The file is sent as a `resource_link` rather than embedded
  `resource`. The agent reads it via its own `read` tool — that path
  is gated by the dispatcher's per-kind permission allowlist, which
  lets the agent see the target file (and the rest of the repo) but
  only edit the target.
#}
[
  {
    "type": "text",
    "text": {{ prompt_text | tojson }}
  },
  {
    "type": "resource_link",
    "uri": {{ target_file_uri | tojson }},
    "name": {{ target_file_name | tojson }}
  }
]
