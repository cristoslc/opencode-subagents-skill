#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["jinja2>=3.1", "PyYAML>=6"]
# ///
"""
opencode-dispatch — route a subagent task through opencode.

ACP mode (default): spawns `opencode acp --port <fixed>`, drives it over
JSON-RPC on stdio, surfaces the attach URL so the operator can attach a
TUI for live inspection. CLI mode falls back to rendering a shell script
from `templates/cli/<kind>.sh.j2` and exec'ing it.

This is the v0.2 reference implementation. See SKILL.md for the design
contract — every behaviour in this script should map to a section there.
"""
from __future__ import annotations

import argparse
import asyncio
import datetime as dt
import hashlib
import json
import os
import shutil
import subprocess
import sys
import urllib.parse
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any

import yaml
from jinja2 import Environment, FileSystemLoader, StrictUndefined

# ---------------------------------------------------------------------------
# Paths and constants

SKILL_DIR = Path(__file__).resolve().parent.parent
TEMPLATES_DIR = SKILL_DIR / "templates"
SCRIPTS_DIR = SKILL_DIR / "scripts"
VERIFY_CWD = SCRIPTS_DIR / "verify-cwd.sh"
VALIDATE_RUN = SCRIPTS_DIR / "validate-run.sh"

# Permission options opencode advertises (from src/acp/agent.ts).
PERMISSION_OPTIONS = ["once", "always", "reject"]

# Per-kind permission allowlist. Keys map ACP `toolCall.kind` values to
# an action (`allow` | `reject` | `<callable>` for path-conditional).
# See SKILL.md "Permission model".
ALLOWLIST: dict[str, dict[str, Any]] = {
    "single-file-fix": {
        "read": "allow",
        "search": "allow",
        # `edit` allowed only on --target-file.
        "edit": "target_only",
        "execute": "reject",
        "delete": "reject",
        "move": "reject",
        "fetch": "reject",
        # Default for any kind not listed:
        "_default": "reject",
    },
    # Each parallel child agent gets its own --target-file context, so
    # the same allowlist as single-file-fix applies per-child.
    "parallel-review-fanout": {
        "read": "allow",
        "search": "allow",
        "edit": "target_only",
        "execute": "reject",
        "delete": "reject",
        "move": "reject",
        "fetch": "reject",
        "_default": "reject",
    },
}


# ---------------------------------------------------------------------------
# Logging

def log(msg: str) -> None:
    print(f"[opencode-dispatch] {msg}", flush=True)


def warn(msg: str) -> None:
    print(f"[opencode-dispatch] warn: {msg}", file=sys.stderr, flush=True)


def fail(msg: str, code: int = 1) -> None:
    print(f"[opencode-dispatch] error: {msg}", file=sys.stderr, flush=True)
    sys.exit(code)


# ---------------------------------------------------------------------------
# Config

@dataclass
class Config:
    mode: str = "acp"
    acp_port: int = 4096
    acp_hostname: str = "127.0.0.1"
    acp_spawn: bool = True
    password_env: str = "OPENCODE_SERVER_PASSWORD"
    default_model: str | None = None
    default_agent: str = "build"
    default_timeout_sec: int = 600
    worktree_root: str | None = None
    templates_dir: Path = TEMPLATES_DIR


def load_config(repo_root: Path) -> Config:
    path = repo_root / ".opencode-dispatch" / "config.yaml"
    if not path.exists():
        return Config()
    with path.open() as fh:
        raw = yaml.safe_load(fh) or {}
    cfg = Config()
    cfg.mode = raw.get("mode", cfg.mode)
    acp = raw.get("acp", {}) or {}
    cfg.acp_port = int(acp.get("port", cfg.acp_port))
    cfg.acp_hostname = acp.get("hostname", cfg.acp_hostname)
    cfg.acp_spawn = bool(acp.get("spawn", cfg.acp_spawn))
    cfg.password_env = acp.get("password_env", cfg.password_env)
    cfg.default_model = raw.get("default_model", cfg.default_model)
    cfg.default_agent = raw.get("default_agent", cfg.default_agent)
    cfg.default_timeout_sec = int(raw.get("default_timeout_sec", cfg.default_timeout_sec))
    cfg.worktree_root = raw.get("worktree_root", cfg.worktree_root)
    return cfg


# ---------------------------------------------------------------------------
# Pre-flight: verify CWD via the existing shell helper.

def verify_cwd(cwd: Path, branch: str | None, worktree: str | None,
               worktree_root: str | None) -> None:
    args: list[str] = [str(VERIFY_CWD), str(cwd)]
    if branch:
        args += ["--branch", branch]
    if worktree:
        if not worktree_root:
            fail("--worktree requires --worktree-root (or worktree_root in config)")
        args += ["--worktree", worktree, "--worktree-root", worktree_root]
    res = subprocess.run(args, capture_output=True, text=True)
    sys.stderr.write(res.stderr)
    if res.returncode != 0:
        fail(f"verify-cwd.sh rejected the path: exit={res.returncode}", code=res.returncode)
    sys.stdout.write(res.stdout)


# ---------------------------------------------------------------------------
# Task directory + template rendering.

def allocate_task_id(prompt_text: str) -> str:
    ts = dt.datetime.now(dt.UTC).strftime("%Y%m%dT%H%M%SZ")
    digest = hashlib.sha256(prompt_text.encode("utf-8")).hexdigest()[:8]
    return f"{ts}-{digest}"


def render_acp_parts(kind: str, prompt_text: str, target_file: Path) -> list[dict]:
    env = Environment(
        loader=FileSystemLoader(TEMPLATES_DIR / "acp"),
        undefined=StrictUndefined,
        keep_trailing_newline=True,
    )
    tpl_name = f"{kind}.prompt.j2"
    tpl_path = TEMPLATES_DIR / "acp" / tpl_name
    if not tpl_path.exists():
        fail(f"no ACP template for kind '{kind}': {tpl_path}")
    tpl = env.get_template(tpl_name)
    target_uri = "file://" + urllib.parse.quote(str(target_file), safe="/")
    rendered = tpl.render(
        prompt_text=prompt_text,
        target_file_uri=target_uri,
        target_file_name=target_file.name,
        target_file_path=str(target_file),
    )
    parts = json.loads(rendered)
    if not isinstance(parts, list):
        fail(f"template {tpl_name} did not render a JSON array")
    return parts


# ---------------------------------------------------------------------------
# ACP client (line-delimited JSON-RPC 2.0 over stdio).

@dataclass
class AcpClient:
    proc: asyncio.subprocess.Process
    events_path: Path
    stdout_path: Path
    next_id: int = 1
    pending: dict[int, asyncio.Future] = field(default_factory=dict)
    permission_handler: Any = None
    closed: bool = False

    async def send(self, obj: dict) -> None:
        line = (json.dumps(obj, separators=(",", ":")) + "\n").encode("utf-8")
        self.proc.stdin.write(line)
        await self.proc.stdin.drain()

    async def request(self, method: str, params: dict, *, timeout: float | None = None) -> Any:
        rid = self.next_id
        self.next_id += 1
        fut: asyncio.Future = asyncio.get_event_loop().create_future()
        self.pending[rid] = fut
        await self.send({"jsonrpc": "2.0", "id": rid, "method": method, "params": params})
        if timeout is None:
            return await fut
        return await asyncio.wait_for(fut, timeout=timeout)

    async def notify(self, method: str, params: dict) -> None:
        await self.send({"jsonrpc": "2.0", "method": method, "params": params})

    async def reply(self, rid: int, result: Any) -> None:
        await self.send({"jsonrpc": "2.0", "id": rid, "result": result})

    async def reply_error(self, rid: int, code: int, message: str) -> None:
        await self.send({"jsonrpc": "2.0", "id": rid, "error": {"code": code, "message": message}})

    async def read_loop(self) -> None:
        events_fh = self.events_path.open("a", encoding="utf-8")
        stdout_fh = self.stdout_path.open("a", encoding="utf-8")
        try:
            while True:
                try:
                    line = await self.proc.stdout.readline()
                except (asyncio.LimitOverrunError, ValueError) as e:
                    warn(f"oversized line on acp stdout (raise the subprocess limit): {e}")
                    break
                if not line:
                    break
                events_fh.write(line.decode("utf-8", errors="replace"))
                events_fh.flush()
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError as e:
                    warn(f"non-JSON line from acp: {line!r} ({e})")
                    continue

                # Response to one of our requests
                if "id" in msg and ("result" in msg or "error" in msg) and "method" not in msg:
                    fut = self.pending.pop(msg["id"], None)
                    if fut is None:
                        warn(f"unexpected response id={msg['id']}")
                        continue
                    if "error" in msg:
                        fut.set_exception(RuntimeError(f"acp error: {msg['error']}"))
                    else:
                        fut.set_result(msg["result"])
                    continue

                # Server-originated request (we must reply)
                if "id" in msg and "method" in msg:
                    await self._handle_server_request(msg)
                    continue

                # Notification
                if "method" in msg:
                    await self._handle_notification(msg, stdout_fh)
                    continue

                warn(f"unrecognized acp message: {msg}")
        finally:
            self.closed = True
            events_fh.close()
            stdout_fh.close()
            for fut in self.pending.values():
                if not fut.done():
                    fut.set_exception(RuntimeError("acp stream closed"))

    async def _handle_server_request(self, msg: dict) -> None:
        method = msg["method"]
        rid = msg["id"]
        params = msg.get("params", {})
        if method == "session/request_permission" and self.permission_handler:
            try:
                outcome = self.permission_handler(params)
                await self.reply(rid, {"outcome": outcome})
            except Exception as e:
                warn(f"permission handler raised: {e}")
                await self.reply(rid, {"outcome": {"outcome": "selected", "optionId": "reject"}})
        else:
            warn(f"unhandled server request: {method}")
            await self.reply_error(rid, -32601, f"method not handled: {method}")

    async def _handle_notification(self, msg: dict, stdout_fh) -> None:
        method = msg["method"]
        params = msg.get("params", {})
        if method == "session/update":
            update = params.get("update", {}) or params  # opencode may send under params or params.update
            kind = update.get("sessionUpdate") or params.get("sessionUpdate")
            content = update.get("content") or params.get("content")
            if kind == "agent_message_chunk" and isinstance(content, dict):
                text = content.get("text", "")
                stdout_fh.write(text)
                stdout_fh.flush()


# ---------------------------------------------------------------------------
# Permission gate

def make_permission_handler(kind: str, target_file: Path | None):
    rules = ALLOWLIST.get(kind, {"_default": "reject"})

    def handle(params: dict) -> dict:
        tool = params.get("toolCall", {}) or {}
        tool_kind = tool.get("kind") or "_default"
        action = rules.get(tool_kind, rules.get("_default", "reject"))

        decision: str
        reason: str
        if action == "allow":
            decision = "once"
            reason = f"kind={tool_kind} allowed"
        elif action == "reject":
            decision = "reject"
            reason = f"kind={tool_kind} rejected by allowlist"
        elif action == "target_only":
            raw = tool.get("rawInput", {}) or {}
            # opencode's edit tool uses `filepath` (one word) — observed in
            # session/request_permission payloads against opencode 1.14.x.
            # The other forms are kept for forward-compat.
            path_str = (raw.get("filepath") or raw.get("file_path")
                        or raw.get("filePath") or raw.get("path"))
            if path_str and target_file and Path(path_str).resolve() == target_file.resolve():
                decision = "once"
                reason = f"edit on --target-file allowed"
            else:
                decision = "reject"
                reason = f"edit on '{path_str}' rejected (only --target-file allowed)"
        else:
            decision = "reject"
            reason = f"unknown allowlist action '{action}', defaulting to reject"

        log(f"permission [{tool.get('title', tool_kind)}] -> {decision} ({reason})")
        return {"outcome": "selected", "optionId": decision}

    return handle


# ---------------------------------------------------------------------------
# Spawning opencode acp

async def spawn_opencode_acp(cfg: Config, task_dir: Path, cwd: Path
                             ) -> asyncio.subprocess.Process:
    binary = shutil.which("opencode")
    if not binary:
        fail("`opencode` not found on PATH")
    env = os.environ.copy()
    env["OPENCODE_DISABLE_AUTOCOMPACT"] = "true"
    env["OPENCODE_DISABLE_AUTOUPDATE"] = "true"
    # OPENCODE_SERVER_PASSWORD is intentionally NOT set. opencode acp's
    # internal SDK client makes HTTP requests to the same embedded
    # server without Basic-auth headers, so a password breaks
    # intra-process calls (initialize succeeds, session/new fails with
    # `Unauthorized failed to load user config for default model`).
    # The 127.0.0.1 hostname is the security boundary; operators on
    # multi-user hosts should set acp.hostname back to localhost in
    # config.yaml and accept that any local user can attach.
    env.pop("OPENCODE_SERVER_PASSWORD", None)
    stderr_fh = (task_dir / "stderr.log").open("w", encoding="utf-8")
    # ACP responses can be very large (session/new returns the full
    # model registry — ~120 KB+ on a typical multi-provider install).
    # Default asyncio StreamReader limit is 64 KiB which trips
    # LimitOverrunError on readline() before the response can be parsed.
    proc = await asyncio.create_subprocess_exec(
        binary, "acp",
        "--port", str(cfg.acp_port),
        "--hostname", cfg.acp_hostname,
        "--cwd", str(cwd),
        "--print-logs",
        "--log-level", "INFO",
        stdin=asyncio.subprocess.PIPE,
        stdout=asyncio.subprocess.PIPE,
        stderr=stderr_fh,
        env=env,
        cwd=str(cwd),
        limit=8 * 1024 * 1024,  # 8 MiB per line
    )
    log(f"spawned opencode acp pid={proc.pid} port={cfg.acp_port} cwd={cwd}")
    return proc


# ---------------------------------------------------------------------------
# Main async dispatch (ACP mode)

async def dispatch_acp(args: argparse.Namespace, cfg: Config, task_dir: Path,
                       prompt_text: str, parts: list[dict]) -> int:
    proc = await spawn_opencode_acp(cfg, task_dir, args.cwd.resolve())

    client = AcpClient(
        proc=proc,
        events_path=task_dir / "events.jsonl",
        stdout_path=task_dir / "stdout.log",
        permission_handler=make_permission_handler(args.kind, Path(args.target_file).resolve() if args.target_file else None),
    )
    reader = asyncio.create_task(client.read_loop())

    try:
        # 1) initialize
        init_resp = await client.request(
            "initialize",
            {
                "protocolVersion": 1,
                "clientCapabilities": {
                    "fs": {"readTextFile": True, "writeTextFile": True},
                    "terminal": False,
                },
                "clientInfo": {
                    "name": "opencode-dispatch",
                    "title": "opencode-dispatch",
                    "version": "0.2.0",
                },
            },
            timeout=30,
        )
        log(f"initialize -> protocolVersion={init_resp.get('protocolVersion')}")

        # 2) session/new
        sess_resp = await client.request(
            "session/new",
            {"cwd": str(args.cwd.resolve()), "mcpServers": []},
            timeout=30,
        )
        session_id = sess_resp["sessionId"]
        log(f"session/new -> sessionId={session_id}")
        log(f"attach: opencode attach http://{cfg.acp_hostname}:{cfg.acp_port} --session {session_id}")
        log(f"        (no password — server is bound to {cfg.acp_hostname} only)")

        # Persist session metadata for replay/audit.
        (task_dir / "session.json").write_text(json.dumps({
            "sessionId": session_id,
            "model": args.model,
            "agent": args.agent,
            "cwd": str(args.cwd.resolve()),
            "attach_url": f"http://{cfg.acp_hostname}:{cfg.acp_port}",
        }, indent=2))

        # 3) Save the prompt request shape for audit.
        prompt_request = {"sessionId": session_id, "prompt": parts}
        (task_dir / "prompt-request.json").write_text(json.dumps(prompt_request, indent=2))

        # 4) session/prompt — blocks until the turn ends (stopReason).
        log(f"prompt: {len(parts)} part(s); awaiting turn (timeout={args.timeout}s)")
        result = await client.request("session/prompt", prompt_request, timeout=args.timeout)
        log(f"prompt -> stopReason={result.get('stopReason')}")
        return 0 if result.get("stopReason") in ("end_turn",) else 2

    except asyncio.TimeoutError:
        warn(f"timeout after {args.timeout}s; cancelling session")
        try:
            await client.notify("session/cancel", {"sessionId": session_id})  # noqa: F821
        except Exception:
            pass
        return 124
    finally:
        try:
            proc.stdin.close()
        except Exception:
            pass
        try:
            await asyncio.wait_for(proc.wait(), timeout=10)
        except asyncio.TimeoutError:
            proc.terminate()
            await proc.wait()
        reader.cancel()
        try:
            await reader
        except (asyncio.CancelledError, Exception):
            pass


# ---------------------------------------------------------------------------
# parallel-review-fanout: N independent children, one opencode acp each.

import copy
import re
import socket


def file_slug(path: str) -> str:
    """Stable, filesystem-safe slug for a path. Used as child task-dir name."""
    s = re.sub(r"[^A-Za-z0-9._-]+", "-", path.strip("/").strip())
    return s[:80].strip("-") or "target"


def find_free_port(start: int, host: str = "127.0.0.1", limit: int = 64) -> int:
    """Find a free TCP port at or after `start`. Raises if none in `limit`."""
    for p in range(start, start + limit):
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            try:
                s.bind((host, p))
            except OSError:
                continue
            return p
    raise RuntimeError(f"no free port in [{start}, {start + limit})")


async def _run_one_child(idx: int, target_rel: str, args: argparse.Namespace,
                         cfg: Config, parent_task_dir: Path,
                         shared_decisions_text: str, per_file_prompt: str,
                         port: int, semaphore: asyncio.Semaphore) -> dict:
    """Run a single child dispatch. Returns a result record."""
    async with semaphore:
        target_abs = (args.cwd / target_rel).resolve()
        if not target_abs.is_relative_to(args.cwd.resolve()):
            return {"target": target_rel, "ok": False,
                    "reason": "target outside cwd", "task_dir": None, "exit": 2}
        if not target_abs.exists():
            return {"target": target_rel, "ok": False,
                    "reason": "target does not exist", "task_dir": None, "exit": 2}

        slug = file_slug(target_rel)
        child_task_dir = parent_task_dir / slug
        child_task_dir.mkdir(exist_ok=True)
        combined = (shared_decisions_text.rstrip()
                    + "\n\n---\n\n"
                    + per_file_prompt.rstrip()
                    + "\n")
        (child_task_dir / "prompt.md").write_text(combined)
        # Render parts using the same single-file-fix template — the
        # parallel-review-fanout kind reuses it (text + resource_link).
        parts = render_acp_parts("single-file-fix", combined, target_abs)
        (child_task_dir / "prompt-parts.json").write_text(
            json.dumps(parts, indent=2))

        # Per-child args/cfg with the kind kept as parallel-review-fanout
        # so the permission allowlist is selected correctly.
        sub_args = copy.copy(args)
        sub_args.target_file = target_abs
        sub_cfg = copy.copy(cfg)
        sub_cfg.acp_port = port

        log(f"child[{idx}] target={target_rel} port={port} task_dir={child_task_dir}")
        try:
            exit_code = await dispatch_acp(sub_args, sub_cfg, child_task_dir,
                                           combined, parts)
        except Exception as e:  # noqa: BLE001
            warn(f"child[{idx}] raised: {e}")
            return {"target": target_rel, "ok": False, "reason": str(e),
                    "task_dir": str(child_task_dir), "exit": 1}

        # Run validate-run.sh on the child's task dir; warn-only.
        val = subprocess.run([str(VALIDATE_RUN), str(child_task_dir)],
                             capture_output=True, text=True)
        if val.returncode != 0:
            warn(f"child[{idx}] validate-run.sh exit={val.returncode}: "
                 f"{val.stderr.strip()[:200]}")

        return {
            "target": target_rel,
            "ok": exit_code == 0,
            "reason": None if exit_code == 0 else f"exit={exit_code}",
            "task_dir": str(child_task_dir),
            "exit": exit_code,
        }


async def dispatch_parallel_fanout(args: argparse.Namespace, cfg: Config,
                                   parent_task_dir: Path,
                                   shared_decisions_text: str,
                                   per_file_prompt: str,
                                   target_files: list[str]) -> int:
    """Fan out N children, one per target file, in parallel."""
    parallelism = args.parallel if args.parallel > 0 else len(target_files)
    semaphore = asyncio.Semaphore(parallelism)

    # Allocate distinct free ports starting from cfg.acp_port.
    ports: list[int] = []
    next_port = cfg.acp_port
    for _ in target_files:
        p = find_free_port(next_port, host=cfg.acp_hostname)
        ports.append(p)
        next_port = p + 1

    log(f"parallel-review-fanout: {len(target_files)} targets, "
        f"parallelism={parallelism}, ports={ports}")

    tasks = [
        asyncio.create_task(_run_one_child(
            i, t, args, cfg, parent_task_dir,
            shared_decisions_text, per_file_prompt, ports[i], semaphore,
        ))
        for i, t in enumerate(target_files)
    ]
    results = await asyncio.gather(*tasks, return_exceptions=False)

    # Persist parent index for replay/audit.
    parent_index = {
        "kind": "parallel-review-fanout",
        "cwd": str(args.cwd),
        "model": args.model,
        "agent": args.agent,
        "parallelism": parallelism,
        "shared_decisions_path": str(args.shared_decisions) if args.shared_decisions else None,
        "children": results,
    }
    (parent_task_dir / "parent.json").write_text(json.dumps(parent_index, indent=2))

    n_ok = sum(1 for r in results if r["ok"])
    log(f"parallel-review-fanout: {n_ok}/{len(results)} children ok")
    for r in results:
        marker = "ok" if r["ok"] else "FAIL"
        log(f"  [{marker}] {r['target']} exit={r['exit']} dir={r['task_dir']}")
    return 0 if n_ok == len(results) else 2


# ---------------------------------------------------------------------------
# CLI entrypoint

def parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(prog="opencode-dispatch")
    p.add_argument("--kind", required=True, choices=["single-file-fix", "parallel-review-fanout", "headless-spike"])
    p.add_argument("--mode", choices=["acp", "cli", "http"], default="acp")
    p.add_argument("--cwd", required=True, type=Path)
    p.add_argument("--branch")
    p.add_argument("--worktree")
    p.add_argument("--worktree-root")
    p.add_argument("--model")
    p.add_argument("--agent")
    p.add_argument("--target-file", type=Path)
    p.add_argument("--target-files", type=str,
                   help="Comma-separated list of target files (parallel-review-fanout)")
    p.add_argument("--shared-decisions", type=Path,
                   help="Path to a shared-decisions doc; prepended to every "
                        "child's prompt (parallel-review-fanout)")
    p.add_argument("--parallel", type=int, default=0,
                   help="Max concurrent children (parallel-review-fanout); "
                        "0 = unlimited (one per target)")
    p.add_argument("--prompt-file", required=True, type=Path)
    p.add_argument("--timeout", type=int)
    p.add_argument("--task-root", type=Path,
                   help="Where to create the task directory (default: <cwd>/.opencode-dispatch)")
    return p.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)

    repo_root = args.cwd.resolve()
    cfg = load_config(repo_root)
    args.cwd = repo_root
    args.model = args.model or cfg.default_model
    args.agent = args.agent or cfg.default_agent
    args.timeout = args.timeout or cfg.default_timeout_sec
    if not args.model:
        fail("--model required (or set default_model in config)")

    if args.kind == "single-file-fix" and not args.target_file:
        fail("--target-file required for kind=single-file-fix")
    if args.kind == "parallel-review-fanout":
        if not args.target_files:
            fail("--target-files required for kind=parallel-review-fanout")
        if not args.shared_decisions:
            fail("--shared-decisions required for kind=parallel-review-fanout")

    # 1) Verify CWD (fail-closed)
    verify_cwd(args.cwd, args.branch, args.worktree, args.worktree_root or cfg.worktree_root)

    # 2) Read the prompt body
    if not args.prompt_file.exists():
        fail(f"prompt-file does not exist: {args.prompt_file}")
    prompt_text = args.prompt_file.read_text(encoding="utf-8")

    # 3) Allocate task dir
    task_root = args.task_root or (args.cwd / ".opencode-dispatch")
    task_root.mkdir(exist_ok=True)
    task_id = allocate_task_id(prompt_text)
    task_dir = task_root / task_id
    task_dir.mkdir()
    log(f"task_id={task_id}  task_dir={task_dir}")

    (task_dir / "prompt.md").write_text(prompt_text)

    if args.mode == "cli":
        fail("--mode cli is not yet wired into this entrypoint; use the rendered "
             "templates/cli/<kind>.sh.j2 directly until v0.3")
    if args.mode == "http":
        fail("--mode http is not implemented in v0.2")

    # ---- parallel-review-fanout: orchestrate N children, then return ----
    if args.kind == "parallel-review-fanout":
        target_list = [t.strip() for t in args.target_files.split(",") if t.strip()]
        if len(target_list) < 1:
            fail("--target-files must list at least one path")
        if len(target_list) != len(set(target_list)):
            fail(f"--target-files contains duplicates: {target_list}")
        sd_path = args.shared_decisions
        if not sd_path.is_absolute():
            sd_path = (args.cwd / sd_path).resolve()
        if not sd_path.exists():
            fail(f"--shared-decisions file does not exist: {sd_path}")
        shared_decisions_text = sd_path.read_text(encoding="utf-8")
        # Persist a copy in the parent task dir for replay/audit.
        (task_dir / "shared-decisions.md").write_text(shared_decisions_text)
        code = asyncio.run(dispatch_parallel_fanout(
            args, cfg, task_dir, shared_decisions_text, prompt_text, target_list,
        ))
        log(f"parent task_dir={task_dir} exit={code}")
        return code

    # ACP mode
    target_file = (args.cwd / args.target_file).resolve() if args.target_file else None
    if target_file:
        if not target_file.is_relative_to(args.cwd):
            fail(f"--target-file must be inside --cwd: {target_file}")
    parts = render_acp_parts(args.kind, prompt_text, target_file) if target_file else []
    (task_dir / "prompt-parts.json").write_text(json.dumps(parts, indent=2))

    code = asyncio.run(dispatch_acp(args, cfg, task_dir, prompt_text, parts))

    # Post-run validate
    val = subprocess.run([str(VALIDATE_RUN), str(task_dir)], capture_output=True, text=True)
    sys.stderr.write(val.stderr)
    sys.stdout.write(val.stdout)
    if val.returncode != 0:
        warn(f"validate-run.sh exited {val.returncode} (note: today's validator targets CLI-mode events; ACP-mode validator is planned)")

    log(f"task_dir={task_dir} exit={code}")
    return code


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
