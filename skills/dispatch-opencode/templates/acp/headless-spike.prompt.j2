{#
  Template: headless-spike (ACP mode)

  Renders the ACP `prompt` parts array for a read-only investigation
  that ends with the agent writing a report to `--report-path`.

  Inputs:
    prompt_text       (str) — the operator's investigation brief
    target_file_uri   (str) — `file://` URI to the report path (the
                              file to be created/overwritten)
    target_file_name  (str) — basename, for display
    target_file_path  (str) — absolute filesystem path of the report

  The agent uses its read/search tools to investigate the codebase and
  the bash_readonly allowlist (git status/diff/log/show/ls-files,
  ls/cat/head/tail/wc/file/grep/find — see ALLOWLIST in dispatch-opencode).
  Source code is not modified; only the report file is written.
#}
[
  {
    "type": "text",
    "text": {{ ("Investigation brief\n\n"
                + prompt_text
                + "\n\n---\n\nWrite your final report to: "
                + target_file_path
                + "\nUse the edit tool to create or overwrite that file. "
                + "Do not modify any other files. "
                + "Use the read, search, glob, grep, and read-only bash tools "
                + "(git status / git diff / git log / git show / ls-files / "
                + "ls / cat / head / tail / wc / file) to gather evidence. "
                + "Bash commands outside this list will be rejected."
               ) | tojson }}
  },
  {
    "type": "resource_link",
    "uri": {{ target_file_uri | tojson }},
    "name": {{ target_file_name | tojson }}
  }
]
